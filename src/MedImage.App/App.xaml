<Application x:Class="MedImage.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MedImage.App.ViewModels"
             xmlns:conv="clr-namespace:MedImage.App.Converters"
             xmlns:views="clr-namespace:MedImage.App.Views">
    <Application.Resources>
        <ResourceDictionary>
            <conv:InverseBooleanConverter x:Key="InverseBool" />
            <conv:StringToVisibilityConverter x:Key="StringToVis" />
            <conv:BooleanToVisibilityConverter x:Key="BoolToVis" />
            <!-- VIEW-MODEL FIRST: map each VM type to its View -->
            <DataTemplate DataType="{x:Type vm:LoginViewModel}">
                <views:LoginView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SignupViewModel}">
                <views:SignupView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:EditorViewModel}">
                <views:EditorView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
