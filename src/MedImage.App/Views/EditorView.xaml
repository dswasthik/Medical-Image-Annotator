<UserControl x:Class="MedImage.App.Views.EditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D6D6DE"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#D6D6DE"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#1E1E24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <DockPanel Grid.Row="0" Background="#26262E" LastChildFill="False">
            <Button Content="Open image" Margin="8,8,4,8" Padding="10,4" Command="{Binding OpenImageCommand}"/>
            <Button Content="Reset"      Margin="4,8"     Padding="10,4" Command="{Binding ResetCommand}"/>
            <Button Content="Save study" Margin="4,8"     Padding="10,4" Command="{Binding SaveCommand}"/>
            <TextBlock DockPanel.Dock="Right" Margin="8" VerticalAlignment="Center"
                       Text="{Binding Welcome}" Foreground="#9A9AA6"/>
            <Button DockPanel.Dock="Right" Content="Log out" Margin="4,8" Padding="10,4"
                    Command="{Binding LogoutCommand}"/>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- Left: adjustments -->
            <ScrollViewer Grid.Column="0" Background="#23232B" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="14">
                    <TextBlock Text="Enhancements" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

                    <CheckBox Content="Grayscale"           IsChecked="{Binding Grayscale}"/>
                    <CheckBox Content="Invert"              IsChecked="{Binding Invert}"/>
                    <CheckBox Content="Sharpen"             IsChecked="{Binding Sharpen}"/>
                    <CheckBox Content="Histogram equalize"  IsChecked="{Binding HistogramEqualize}"/>

                    <TextBlock Text="Contrast" Margin="0,16,0,0"/>
                    <Slider Minimum="0.5" Maximum="3.0" Value="{Binding Contrast}" TickFrequency="0.1"/>

                    <TextBlock Text="Brightness" Margin="0,10,0,0"/>
                    <Slider Minimum="-100" Maximum="100" Value="{Binding Brightness}" TickFrequency="5"/>

                    <CheckBox Content="Window / Level" IsChecked="{Binding WindowLevelEnabled}" Margin="0,16,0,0"/>
                    <TextBlock Text="Window (width)" Margin="0,8,0,0"/>
                    <Slider Minimum="1" Maximum="255" Value="{Binding Window}"/>
                    <TextBlock Text="Level (center)" Margin="0,8,0,0"/>
                    <Slider Minimum="0" Maximum="255" Value="{Binding Level}"/>

                    <TextBlock Margin="0,18,0,0" Foreground="#8A8A96" TextWrapping="Wrap"
                               Text="Tip: drag on the image to measure a distance (in pixels)."/>
                </StackPanel>
            </ScrollViewer>

            <!-- Center: image + annotation overlay -->
            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto" Background="#141418">
                <Grid x:Name="ImageHost" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16">
                    <Image x:Name="PreviewImage" Source="{Binding DisplayImage}" Stretch="None"/>

                    <!-- committed measurements -->
                    <ItemsControl ItemsSource="{Binding Measurements}" IsHitTestVisible="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Line X1="{Binding X1}" Y1="{Binding Y1}"
                                      X2="{Binding X2}" Y2="{Binding Y2}"
                                      Stroke="#FFEB3B" StrokeThickness="2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- drawing surface -->
                    <Canvas x:Name="Overlay" Background="Transparent"
                            MouseLeftButtonDown="Overlay_MouseLeftButtonDown"
                            MouseMove="Overlay_MouseMove"
                            MouseLeftButtonUp="Overlay_MouseLeftButtonUp">
                        <Line x:Name="TempLine" Stroke="#FFF176" StrokeThickness="2" Visibility="Collapsed"/>
                    </Canvas>
                </Grid>
            </ScrollViewer>

            <!-- Right: study details + history -->
            <Grid Grid.Column="2" Background="#23232B">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="14">
                    <TextBlock Text="Study" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="Title" Margin="0,8,0,0"/>
                    <TextBox Text="{Binding StudyTitle, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,3,0,0"/>
                    <TextBlock Text="Patient ref (optional)" Margin="0,10,0,0"/>
                    <TextBox Text="{Binding PatientRef, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,3,0,0"/>

                    <DockPanel Margin="0,12,0,0">
                        <TextBlock Text="Measurements" FontWeight="Bold"/>
                        <Button DockPanel.Dock="Right" Content="Clear" Padding="8,2"
                                Command="{Binding ClearMeasurementsCommand}" Width="84"/>
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding Measurements}" Margin="0,6,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Label}" Foreground="#FFEB3B"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <DockPanel Grid.Row="1" Margin="14,4,14,4">
                    <TextBlock Text="My studies" FontWeight="Bold" RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform AngleY="0.969"/>
                                <RotateTransform/>
                                <TranslateTransform Y="0.516"/>
                            </TransformGroup>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <Button DockPanel.Dock="Right" Content="Refresh" Padding="8,2"
                            Command="{Binding RefreshHistoryCommand}" Width="84" RenderTransformOrigin="0.897,0.529"/>
                </DockPanel>

                <Grid Grid.Row="2" Margin="14,0,14,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListBox x:Name="HistoryList" Grid.Row="0" ItemsSource="{Binding History}"
                             Background="#1B1B22" Foreground="#D6D6DE" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Display}" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Grid.Row="1" Content="Open selected study" Margin="0,8,0,0" Padding="6"
                            Command="{Binding OpenStudyCommand}"
                            CommandParameter="{Binding SelectedItem, ElementName=HistoryList}"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
