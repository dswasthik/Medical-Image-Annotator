<UserControl x:Class="MedImage.App.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#1E1E24">
        <Border Width="360" Padding="28" CornerRadius="10" Background="#2A2A33"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="MedImage" FontSize="26" FontWeight="Bold" Foreground="#E6E6EA"/>
                <TextBlock Text="Sign in to continue" Foreground="#9A9AA6" Margin="0,2,0,20"/>

                <TextBlock Text="Username" Foreground="#C8C8D0"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Padding="6" Margin="0,4,0,12"/>

                <TextBlock Text="Password" Foreground="#C8C8D0"/>
                <PasswordBox x:Name="PasswordBox" Padding="6" Margin="0,4,0,12"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <TextBlock Text="{Binding Error}" Foreground="#FF6B6B" TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Visibility="{Binding Error, Converter={StaticResource StringToVis}}"/>

                <Button Content="Sign in" Height="38" Command="{Binding LoginCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                        Background="#4C6FFF" Foreground="White" BorderThickness="0" Cursor="Hand"/>

                <Button Content="Create an account" Margin="0,10,0,0"
                        Command="{Binding GoToSignupCommand}"
                        Background="Transparent" Foreground="#9AB0FF" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
